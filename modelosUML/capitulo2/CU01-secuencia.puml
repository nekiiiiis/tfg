@startuml

actor "Usuario" as U
participant "Sistema" as S
participant "Hyperliquid" as HL

U -> S : Seleccionar mercado, token y temporalidad
S -> HL : Suscribirse a WebSocket (trades)
HL --> S : Stream de operaciones

S -> S : Calcular volumenes por direccion
S -> S : Resolver nombres de entidades
S --> U : Mostrar leaderboard

loop Mientras permanece en la vista
  HL --> S : Nueva operacion
  S -> S : Recalcular volumenes
  S --> U : Actualizar leaderboard
end

@enduml
