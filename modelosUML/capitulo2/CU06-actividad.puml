@startuml

start

:Obtener alertas activas;

while (Quedan alertas?) is (si)
  :Obtener precio actual del token;

  if (Precio traspasa umbral?) then (si)
    :Marcar alerta como Disparada;
    :Ejecutar CU-07 Enviar notificacion;
  else (no)
  endif

  :Siguiente alerta;
endwhile (no)

:Esperar intervalo de evaluacion;

stop

@enduml
