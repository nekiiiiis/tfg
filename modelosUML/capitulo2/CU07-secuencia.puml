@startuml

participant "Sistema" as S
participant "Webhook" as SW

S -> S : Generar notificacion
S -> SW : POST (token, precio, umbral)

alt Respuesta exitosa
  SW --> S : 200 OK
  S -> S : Marcar como Notificada
  S -> S : Rearmar alerta a Activa
else Error o timeout
  SW --> S : Error
  S -> S : Marcar como Error
  S -> S : Programar reintento
end

@enduml
