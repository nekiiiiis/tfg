@startuml

rectangle "Sistema\nHerramientas en Tiempo Real\nsobre la L1 de Hyperliquid" as S

actor "Usuario" as U
actor "Hyperliquid L1" as HL
actor "Servicio Webhook" as SW

U -right-> S : Consulta leaderboard\nGestiona entidades\nConfigura alertas

HL -down-> S : Precios en tiempo real\nOperaciones (trades)\nvia API REST y WebSocket

S -right-> SW : Notificaciones\nde alertas disparadas

@enduml
