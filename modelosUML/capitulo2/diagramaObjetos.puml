@startuml

hide circle
hide stereotype

object "trader1 : Usuario" as u1

object "Wintermute : Entidad" as e1 {
  nombre = "Wintermute"
}

object "0xabc1 : Direccion" as d1 {
  hash = "0xabc1...f3"
}

object "0xdef2 : Direccion" as d2 {
  hash = "0xdef2...a7"
}

object "BTC : Token" as t1 {
  nombre = "BTC"
}

object "PerpNativo : Mercado" as m1 {
  tipo = PerpNativo
}

object "PURR : Token" as t2 {
  nombre = "PURR"
}

object "Spot : Mercado" as m2 {
  tipo = Spot
}

object "pBTC : Precio" as p1 {
  valor = 98500
}

object "compra500k : Operacion" as op1 {
  volumen = 500000
  tipo = compra
}

object "alertaBTC : AlertaPrecio" as a1 {
  umbral = 100000
}

object "alertaPURR : AlertaPrecio" as a2 {
  umbral = 0.50
}

object "whDiscord : Webhook" as w1 {
  url = "https://discord..."
}

u1 --> e1 : crea
u1 -d-> a1 : configura
u1 -d-> a2 : configura
e1 --> d1 : agrupa
e1 --> d2 : agrupa
d1 --> op1 : ejecuta
op1 --> t1 : sobre
t1 --> m1 : pertenece a
t1 -r-> p1 : tiene
t2 --> m2 : pertenece a
a1 --> t1 : monitoriza
a2 --> t2 : monitoriza
a1 -r-> w1 : notifica via
a2 -r-> w1 : notifica via

@enduml
