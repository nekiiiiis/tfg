@startuml

left to right direction

actor "Usuario" as U
actor "Hyperliquid L1" as HL
actor "Servicio Webhook" as SW

package "Sistema" {
  package "Leaderboard" {
    usecase "Consultar leaderboard" as CU01
  }

  package "Entidades" {
    usecase "Crear entidad" as CU02
    usecase "Gestionar entidades" as CU03
  }

  package "Alertas" {
    usecase "Configurar alerta" as CU04
    usecase "Gestionar alertas" as CU05
    usecase "Evaluar alertas" as CU06
    usecase "Enviar notificacion" as CU07
  }
}

U --> CU01
U --> CU02
U --> CU03
U --> CU04
U --> CU05

HL --> CU01
HL --> CU06

CU07 --> SW

CU06 ..> CU07 : <<include>>

@enduml
