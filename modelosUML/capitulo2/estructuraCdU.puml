@startuml

left to right direction

actor "Usuario" as U
actor "Hyperliquid L1" as HL
actor "Servicio Webhook" as SW

rectangle "Sistema" {
  usecase "CU-01\nConsultar leaderboard" as UC01

  usecase "CU-02\nCrear entidad"    as UC02
  usecase "CU-03\nAbrir entidades"  as UC03
  usecase "CU-04\nEditar entidad"   as UC04
  usecase "CU-05\nEliminar entidad" as UC05

  usecase "CU-06\nAñadir dirección"   as UC06
  usecase "CU-07\nAbrir direcciones"  as UC07
  usecase "CU-08\nEliminar dirección" as UC08

  usecase "CU-09\nCrear alerta de precio"    as UC09
  usecase "CU-10\nAbrir alertas de precio"   as UC10
  usecase "CU-11\nEditar alerta de precio"   as UC11
  usecase "CU-12\nEliminar alerta de precio" as UC12

  usecase "CU-13\nEvaluar alertas activas" as UC13
  usecase "CU-14\nEnviar notificación"     as UC14
  usecase "reintentoNotificación"          as UCRN
}

U --> UC01
U --> UC02
U --> UC03
U --> UC09
U --> UC10

HL --> UC01
HL --> UC13

UC14 --> SW

UC04 ..> UC03 : <<include>>
UC05 ..> UC03 : <<include>>
UC06 ..> UC03 : <<include>>
UC07 ..> UC03 : <<include>>
UC08 ..> UC07 : <<include>>
UC11 ..> UC10 : <<include>>
UC12 ..> UC10 : <<include>>
UC13 ..> UC14 : <<include>>

UCRN ..> UC14 : <<extend>>\n(si el webhook\nno confirma)

@enduml
