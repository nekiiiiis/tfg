@startuml
skinparam packageStyle rectangle
skinparam shadowing false
hide stereotype
left to right direction

actor "Usuario" as U
actor "Hyperliquid L1" as HL
actor "Servicio Webhook" as SW

package "Presentación" as PRES #E3F2FD {
    [Routes Fastify\n(REST)] as REST
    [Gateway WS\n(/ws/leaderboard)] as WS
    [SPA React\n(/public)] as SPA
}

package "Infraestructura" as INFRA #FFF3E0 {
    [PublicWsAdapter\n(IHyperliquidSource)] as HLC
    [NanorethRpcAdapter\n(IHyperliquidSource)] as NRA
    [WebhookConnector] as WHC
    [Drizzle ORM\n(postgres-js)] as DRZ
    [TypedBus\n(EventEmitter)] as BUS
}

package "Aplicación" as APP #E8F5E9 {
    [LeaderboardService] as LS
    [TradePersistence] as TP
    [CatalogoService] as CS
    [MetaService] as MS
    [AlertasService] as AS
    [wireEvaluacion] as EV
    [NotificacionService\n+ RetryWorker] as NS
}

package "Dominio" as DOM #F3E5F5 {
    [Tipos del dominio\n(Mercado, Token,\nOperacion, Precio, …)]
    [DomainEventMap]
    [DomainError]
}

U --> REST  : HTTPS
U --> WS    : WebSocket
U --> SPA   : HTML/JS/CSS
HL --> HLC  : WebSocket + REST
HLC --> WHC : (no aplica)
WHC --> SW  : HTTPS POST

REST ..> APP
WS   ..> APP
HLC  ..> APP
NRA  ..> APP
WHC  ..> APP
DRZ  ..> APP
BUS  ..> APP

APP --> DOM
INFRA --> DOM
PRES --> DOM

note right of DOM
  Capa pura.
  Sin dependencias externas.
end note

note bottom of APP
  Composición manual en
  server.ts (composition root).
  Inyección por constructor.
end note

note bottom of INFRA
  Puerto hexagonal único:
  IHyperliquidSource con
  dos adaptadores intercambiables
  (RS-08).
end note

@enduml
