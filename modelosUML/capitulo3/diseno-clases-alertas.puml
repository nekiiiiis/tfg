@startuml
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "presentación" {
    class registerAlertasRoutes <<gateway>> {
        + POST /api/alertas
        + GET /api/alertas
        + PATCH /api/alertas/:id
        + DELETE /api/alertas/:id
    }
}

package "modules/alertas" {
    class AlertasService <<service>> {
        - db : DB
        - webhook : WebhookConnector
        + crear(input)
        + listar(filtro?)
        + actualizar(id, cambios)
        + eliminar(id)
        + recuperarOperativasPorToken(token)
        + marcarComoDisparada(id)
    }
}

package "modules/notificacion" {
    class WebhookConnector <<adapter>> {
        + checkReachability(url) : Promise<boolean>
        + transmit(url, payload) : Promise<void>
    }
}

package "domain" {
    class AlertaPrecio <<entity>> {
        + id : UUID
        + token : string
        + mercado : Mercado
        + umbral : Umbral
        + webhook : Webhook
        + estado : EstadoAlerta
    }
    enum EstadoAlerta {
        OPERATIVA
        DISPARADA
        NOTIFICACION_FALLIDA
    }
    class Umbral <<value>> {
        + cruce : "SUBE" | "BAJA"
        + valor : Numeric
    }
    class Webhook <<value>> {
        + url : URL  (cifrada en BD)
    }
}

package "persistence" {
    class "tabla alertas\n(webhook_url_enc bytea)" as TA <<table>> #ECEFF1
    class "pgcrypto\npgp_sym_encrypt / decrypt" as PGC <<infrastructure>> #ECEFF1
}

registerAlertasRoutes ..> AlertasService
AlertasService ..> TA
AlertasService ..> PGC : cifrar / descifrar
AlertasService ..> WebhookConnector : checkReachability
AlertasService ..> AlertaPrecio
AlertaPrecio --> EstadoAlerta
AlertaPrecio --> Umbral
AlertaPrecio --> Webhook

note right of TA
  Índice (token_simbolo, estado)
  para CU-13 (RS-02).
end note

note bottom of PGC
  RS-10: la URL nunca queda
  en BD en texto plano; la
  clave maestra (APP_SECRET)
  vive en el proceso.
end note

@enduml
