@startuml
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "modules/evaluacion" {
    class wireEvaluacion <<handler>> {
        + on('PrecioActualizado', payload)
    }
    class evaluarAlertasContraPrecio <<pure>> {
        + (alertas, precio) : ids[]
    }
}

package "domain" {
    class evaluarUmbral <<pure>> {
        + (umbral, precio) : boolean
    }
    class Umbral <<value>>
}

package "modules/notificacion" {
    class NotificacionService <<service>> {
        - db : DB
        - webhook : WebhookConnector
        + dispararParaAlerta(alertaId, precio)
        + transmitirYActualizar(notifId)
        + listarPorAlerta(alertaId)
    }
    class WebhookConnector <<adapter>> {
        + checkReachability(url)
        + transmit(url, payload)
    }
    class startRetryWorker <<service>> {
        + tick()
    }
}

package "domain" {
    class Notificacion <<entity>> {
        + id : UUID
        + alertaId : UUID
        + precioDisparador : Numeric
        + instanteEmision : timestamp
        + estado : EstadoEntrega
        + intento : int
        + proximoIntento : timestamp
    }
    enum EstadoEntrega {
        PENDIENTE
        ENTREGADA
        FALLIDA
    }
}

package "persistence" {
    class "tabla notificaciones\n(idx estado, proximo_intento)" as TN <<table>> #ECEFF1
    class "tabla alertas" as TA <<table>> #ECEFF1
}

package "bus" {
    class TypedBus <<infrastructure>>
}

TypedBus ..> wireEvaluacion : on('PrecioActualizado')
wireEvaluacion ..> TA : SELECT alertas OPERATIVAS por token
wireEvaluacion ..> evaluarAlertasContraPrecio
evaluarAlertasContraPrecio ..> evaluarUmbral
evaluarUmbral ..> Umbral
wireEvaluacion ..> TA : UPDATE estado='DISPARADA'
wireEvaluacion ..> TypedBus : emit('AlertaDisparada')
wireEvaluacion ..> NotificacionService : dispararParaAlerta

NotificacionService ..> TN
NotificacionService ..> TA : UPDATE estado alerta
NotificacionService ..> WebhookConnector
NotificacionService ..> TypedBus : emit('NotificacionConfirmada' | 'NotificacionFallida')
NotificacionService ..> Notificacion
Notificacion --> EstadoEntrega
startRetryWorker ..> TN : SELECT pendientes vencidas
startRetryWorker ..> NotificacionService : transmitirYActualizar

note right of evaluarAlertasContraPrecio
  Función pura: facilita
  pruebas unitarias sin BD
  ni red.
end note

note right of startRetryWorker
  Tick configurable
  (NOTIFICATION_RETRY_TICK_SECONDS).
  Materializa la cola virtual de
  reintentos sobre Postgres (RS-07).
end note

@enduml
