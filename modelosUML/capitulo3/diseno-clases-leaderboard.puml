@startuml
skinparam shadowing false
skinparam classAttributeIconSize 0
hide circle

package "presentación / leaderboard" {
    class registerLeaderboardGateway <<gateway>> {
        + handle('subscribe', terna, ws)
        + handle('unsubscribe', terna, ws)
    }
}

package "modules/leaderboard" {
    class LeaderboardService <<service>> {
        - source : IHyperliquidSource
        - meta : MetaService
        - state : LeaderboardState
        - persistence? : TradePersistence
        + subscribe(terna, opts) : { snapshot, unsubscribe }
        + snapshot(terna, topN, lado)
        + close()
    }
    class LeaderboardState {
        - windowSecondsByTemp
        - maxOps
        + ingest(terna, op)
        + ingestBackfill(terna, ops[])
        + snapshot(terna, topN, lado)
    }
    class TradePersistence <<service>> {
        + enqueue(op)
        + enqueueMany(ops)
        + flush()
        + getHistorical(mercado, token, sinceMs, untilMs?)
        + cleanup()
        + start()
        + stop()
    }
    class LeaderboardBalancesService <<service>> {
        - meta : MetaService
        + batchBalances(addrs[]) : Saldo[]
    }
}

package "modules/meta" {
    class MetaService <<service>> {
        + resolveToken(mercado, displayToken) : Resolved
        + resolveByFeedCoin(feedCoin)
        + getMidsKeyToDisplay() : Map
        + getCandles(...)
        + getTopVolume(...)
    }
}

package "sources" {
    interface IHyperliquidSource <<port>> {
        + subscribeTrades(feedCoin, onTrade)
        + subscribeAllMids(onAllMids)
        + getRecentTrades(feedCoin) : Trade[]
        + close()
    }
    class PublicWsAdapter <<adapter>> #FFF3E0
    class NanorethRpcAdapter <<adapter>> #FFF3E0
}

package "persistence" {
    class "tabla lb_trades" as LBT <<table>> #ECEFF1
    class "tabla direcciones / entidades" as CAT <<table>> #ECEFF1
}

package "bus" {
    class TypedBus <<infrastructure>>
}

registerLeaderboardGateway ..> LeaderboardService
registerLeaderboardGateway ..> TypedBus : on('LeaderboardActualizado')
LeaderboardService ..> IHyperliquidSource
LeaderboardService ..> MetaService
LeaderboardService ..> LeaderboardState
LeaderboardService ..> TradePersistence
LeaderboardService ..> TypedBus : emit('LeaderboardActualizado')
TradePersistence ..> LBT
LeaderboardBalancesService ..> MetaService
PublicWsAdapter ..|> IHyperliquidSource
NanorethRpcAdapter ..|> IHyperliquidSource
registerLeaderboardGateway ..> CAT : resolverDirecciones (vía CatalogoService)

note right of LeaderboardState
  Estado caliente in-memory:
  ventana deslizante por
  terna (mercado, token,
  temporalidad).
end note

note bottom of NanorethRpcAdapter
  Esqueleto no funcional.
  Existe para validar RS-08
  (sustituibilidad).
end note

@enduml
