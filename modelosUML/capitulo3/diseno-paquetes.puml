@startuml
skinparam packageStyle rectangle
skinparam shadowing false
hide stereotype

package "src/app/src" as APP {
    package "server.ts\n<<composition root>>" as ROOT #ECEFF1
    package "bus.ts (TypedBus)" as BUS #ECEFF1
    package "config.ts" as CFG #ECEFF1

    package "domain" as DOM #F3E5F5 {
        package "types"
        package "events"
        package "errors"
    }

    package "sources" as SRC #FFF3E0 {
        package "hyperliquid.port"
        package "public-ws.adapter"
        package "nanoreth-rpc.adapter"
        package "factory"
    }

    package "modules" as MODS #E8F5E9 {
        package "leaderboard" as LB
        package "catalogo" as CAT
        package "meta" as META
        package "direccion-detalle" as DD
        package "alertas" as AL
        package "evaluacion" as EV
        package "notificacion" as NOT
    }

    package "persistence" as PERS #FFF3E0 {
        package "schema/*"
        package "migrations/*"
        package "db / crypto / ensure-schema"
    }

    package "shared" as SH #ECEFF1 {
        package "logger"
        package "errors (HTTP)"
        package "health"
    }
}

package "src/web/src" as WEB {
    package "pages" #E3F2FD
    package "features" #E3F2FD
    package "components/ui" #E3F2FD
    package "core (api, AppDataContext, …)" #E3F2FD
}

ROOT ..> MODS
ROOT ..> SRC
ROOT ..> PERS
ROOT ..> SH
ROOT ..> BUS

LB ..> SRC
LB ..> META
LB ..> PERS
LB ..> BUS
CAT ..> PERS
META ..> SH
DD ..> SRC
DD ..> META
AL ..> PERS
AL ..> NOT
EV ..> BUS
EV ..> PERS
EV ..> NOT
NOT ..> PERS
NOT ..> BUS
SRC ..> DOM
PERS ..> DOM
MODS ..> DOM

WEB ..> APP : HTTP REST / WS

note bottom of DOM
  Sin dependencias salientes.
  Reutilizable desde cualquier
  capa por composición.
end note

note bottom of MODS
  Organización por feature
  (no por capa): cada CdU
  vive en su subcarpeta con
  servicios + rutas + estado.
end note

@enduml
