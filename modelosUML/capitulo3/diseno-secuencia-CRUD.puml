@startuml
scale 0.75
skinparam shadowing false
skinparam maxMessageSize 120

actor Usuario as U
participant "React UI" as V
participant "Routes" as C
participant "Zod" as Z
participant "Service" as S
participant "Drizzle" as R

U -> V : UI
V -> C : HTTP CRUD
C -> Z : parse
Z --> C : DTO o 400
C -> S : método CdU
activate S
S -> S : invariantes
S -> R : SQL
R --> S : resultado
S --> C : entidad
deactivate S
C --> V : 2xx / 4xx
V --> U : confirmación

note over S
  DomainError → HTTP
  (errors.ts)
end note

@enduml
