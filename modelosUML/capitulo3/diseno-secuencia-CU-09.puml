@startuml
scale 0.75
skinparam shadowing false
skinparam maxMessageSize 120

actor Usuario as U
participant "React UI" as VIEW
participant "Routes" as CTRL
participant "AlertasSvc" as SVC
participant "WebhookConn" as WHC
participant "Drizzle" as DB
participant "pgcrypto" as CRY

U -> VIEW : formulario alerta
VIEW -> CTRL : POST /api/alertas
CTRL -> CTRL : validar Zod
CTRL -> SVC : crear(input)
activate SVC
SVC -> SVC : validar invariantes
SVC -> WHC : checkReachability
WHC -->> SVC : ok / fallo (aviso)
SVC -> CRY : encryptWebhook
CRY --> SVC : webhook_url_enc
SVC -> DB : INSERT OPERATIVA
DB --> SVC : alerta
SVC --> CTRL : alerta + aviso
deactivate SVC
CTRL --> VIEW : 201
VIEW --> U : confirmación

note right of SVC
  Alta aunque webhook caído;
  RS-07 reintenta al disparar.
end note

@enduml
