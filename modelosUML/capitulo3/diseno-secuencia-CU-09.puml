@startuml
skinparam shadowing false

actor "Usuario" as U
participant "AlertasPage\n+ AlertaForm\n(React)" as VIEW
participant "registerAlertasRoutes\n<<gateway>>" as CTRL
participant "AlertasService\n<<service>>" as SVC
participant "WebhookConnector\n<<adapter>>" as WHC
participant "Drizzle\n(tabla alertas)" as DB
participant "pgcrypto\n(pgp_sym_encrypt)" as CRY

U -> VIEW : completar formulario
VIEW -> CTRL : POST /api/alertas\n{mercado, token, umbral, webhookUrl}
CTRL -> CTRL : validar con Zod

CTRL -> SVC : crear(input)
activate SVC

SVC -> SVC : validar invariantes\n(umbral.valor > 0, URL)

SVC -> WHC : checkReachability(webhookUrl)
activate WHC
WHC -->> SVC : alcanzable? (no bloqueante)
deactivate WHC

SVC -> CRY : encryptWebhook(webhookUrl)
CRY --> SVC : bytea (webhook_url_enc)

SVC -> DB : INSERT alerta\nestado = OPERATIVA
DB --> SVC : alerta creada

SVC --> CTRL : alerta + aviso de alcanzabilidad
deactivate SVC

CTRL --> VIEW : 201 Created
VIEW --> U : confirmación + aviso\n(si webhook no alcanzable)

note right of SVC
  El alta queda registrada
  aunque el webhook no
  responda: RS-07 cubre
  reintentos al disparar.
end note

@enduml
