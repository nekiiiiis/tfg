@startuml
scale 0.75
skinparam shadowing false
skinparam maxMessageSize 120

participant "wireEval" as EV
participant "NotifSvc" as NS
participant "DB notif" as DB
participant "pgcrypto" as CRY
participant "WebhookConn" as WHC
actor "Webhook" as SW
participant "DB alertas" as ADB
participant "Bus" as BUS
participant "RetryWorker" as RW

== Disparo (CU-13) ==

EV -> NS : dispararParaAlerta
activate NS
NS -> DB : INSERT PENDIENTE
DB --> NS : notifId
NS -> NS : transmitir (background)
activate NS
NS -> DB : SELECT + decrypt
DB --> NS : url
NS -> WHC : transmit
WHC -> SW : POST JSON
alt OK
    SW --> WHC : 2xx
    NS -> DB : ENTREGADA
    NS -> ADB : OPERATIVA
    NS ->> BUS : Confirmada
else fallo
    SW --> WHC : error
    NS -> DB : FALLIDA + proximo_intento
    NS -> ADB : NOTIFICACION_FALLIDA
    NS ->> BUS : Fallida
end
deactivate WHC
deactivate NS
deactivate NS

== Reintento periódico ==

loop tick retry
    RW -> DB : SELECT pendientes
    DB --> RW : lista
    RW -> NS : transmitirYActualizar
end

@enduml
