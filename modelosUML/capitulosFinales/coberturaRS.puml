@startuml

skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle
hide stereotype

title Cobertura del MVP sobre los requisitos suplementarios

package "Rendimiento" {
  rectangle "RS-01\nLeaderboard ≤ 1 s" as RS01
  rectangle "RS-02\nEvaluación ≤ 2 s" as RS02
}

package "Disponibilidad" {
  rectangle "RS-03\n24/7" as RS03
}

package "Extensibilidad" {
  rectangle "RS-04\nNuevos consumidores\nsin tocar el resto" as RS04
}

package "Usabilidad" {
  rectangle "RS-05\nÁreas independientes" as RS05
  rectangle "RS-06\nMercados distinguidos" as RS06
}

package "Fiabilidad" {
  rectangle "RS-07\nReintentos de\nnotificación" as RS07
}

package "Escalabilidad" {
  rectangle "RS-08\nSustituibilidad de\nla fuente" as RS08
}

package "Trazabilidad y seguridad" {
  rectangle "RS-09\nNotificaciones\ntrazadas" as RS09
  rectangle "RS-10\nWebhooks\ncifrados" as RS10
}

note bottom of RS01 : Pipeline WS in-process\n· leaderboard.service.ts
note bottom of RS02 : PrecioActualizado + índice\n· evaluacion.subscriber.ts
note bottom of RS03 : Compose + healthchecks\n· docker-compose.yml
note bottom of RS04 : TypedBus + evaluator puro\n· bus.ts, domain/events.ts
note bottom of RS05 : Tres rutas raíz SPA\n· web/src/App.tsx
note bottom of RS06 : Mercado como tipo del dominio\n· domain/types.ts
note bottom of RS07 : RetryWorker + backoff\n· retry.worker.ts
note bottom of RS08 : Puerto IHyperliquidSource\n· public-ws.adapter.ts · nanoreth-rpc.adapter.ts
note bottom of RS09 : Tabla notificaciones\n· schema/notificaciones.ts
note bottom of RS10 : pgcrypto + APP_SECRET\n· persistence/crypto.ts

@enduml
