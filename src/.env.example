# ------------------------------------------------------------------------------
# Configuración de la aplicación. Copiar a `.env` y rellenar.
# ------------------------------------------------------------------------------

# Entorno: development | production | test
NODE_ENV=development

# Servidor HTTP/WS de la app
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

# Origen permitido para CORS desde el frontend en desarrollo (Vite)
CORS_ORIGIN=http://localhost:5173

# ------------------------------------------------------------------------------
# Fuente de datos de Hyperliquid (RS-08)
#   public-ws  → wss://api.hyperliquid.xyz/ws + REST /info  (por defecto)
#   nanoreth   → JSON-RPC contra un nodo nanoreth local (futuro)
# ------------------------------------------------------------------------------
HYPERLIQUID_SOURCE=public-ws
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws
HYPERLIQUID_INFO_URL=https://api.hyperliquid.xyz/info
NANORETH_RPC_URL=http://localhost:8545

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=infinite_fieldx
POSTGRES_USER=fieldx
POSTGRES_PASSWORD=fieldx_dev_password_change_me
DATABASE_URL=postgres://fieldx:fieldx_dev_password_change_me@localhost:5432/infinite_fieldx

# ------------------------------------------------------------------------------
# Clave maestra para cifrar URLs de webhook (RS-10). 32 bytes en base64.
# Generar con: openssl rand -base64 32
# ------------------------------------------------------------------------------
APP_SECRET=replace_me_with_32_random_bytes_in_base64

# ------------------------------------------------------------------------------
# Ventanas del leaderboard (sliding window por temporalidad). Segundos.
# ------------------------------------------------------------------------------
LEADERBOARD_WINDOW_1H=3600
LEADERBOARD_WINDOW_4H=14400
LEADERBOARD_WINDOW_6H=21600
LEADERBOARD_WINDOW_12H=43200
LEADERBOARD_WINDOW_1D=86400
LEADERBOARD_WINDOW_1W=604800

# Retención máxima de operaciones por terna en memoria (corte por seguridad).
LEADERBOARD_MAX_OPS_PER_TERNA=200000

# ------------------------------------------------------------------------------
# Política de reintentos de notificación (RS-07).
# Lista de delays acumulados en segundos: 1s, 5s, 30s, 5min, 30min, 1h.
# ------------------------------------------------------------------------------
NOTIFICATION_RETRY_BACKOFF_SECONDS=1,5,30,300,1800,3600
NOTIFICATION_RETRY_TICK_SECONDS=5

# ------------------------------------------------------------------------------
# Umbral de salud del feed de Hyperliquid (segundos sin mensaje → degraded).
# ------------------------------------------------------------------------------
HYPERLIQUID_FEED_STALE_SECONDS=15

# ------------------------------------------------------------------------------
# Pares que se abren automáticamente al arrancar el server para mantener vivo
# el canal Hyperliquid (WS de trades + polling REST + persistencia en
# `lb_trades`) sin depender de que un usuario tenga la web abierta. Útil para
# que las ventanas 1d/1w lleguen "llenas" a la demo de defensa.
#
# Formato: CSV de `Mercado|Token`. Se usa `|` (no `:`) porque PerpHIP3 ya
# usa `:` dentro del token (`<dex>:<symbol>`). Vacío = sin prewarm.
#
# Convención de tokens (display):
#   - PerpNativo:  "<SYMBOL>.p"          (BTC.p, ETH.p, HYPE.p, …)
#   - Spot:        "<base>/<quote>"      (HYPE/USDC, UBTC/USDC, …)
#   - PerpHIP3:    "<dex>:<symbol>"      (xyz:SP500, …)
#
# Ejemplo (3 majors perp + 3 spot líquidos + 3 HIP3):
# LEADERBOARD_PREWARM=PerpNativo|BTC.p,PerpNativo|ETH.p,PerpNativo|HYPE.p,Spot|HYPE/USDC,Spot|UBTC/USDC,Spot|UETH/USDC,PerpHIP3|xyz:SP500,PerpHIP3|xyz:NDX,PerpHIP3|xyz:GLD
# ------------------------------------------------------------------------------
LEADERBOARD_PREWARM=
