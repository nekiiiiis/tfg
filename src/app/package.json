{
  "name": "@infinite-fieldx/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Backend Fastify para herramientas en tiempo real sobre Hyperliquid L1",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/persistence/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/static": "9.1.3",
    "@fastify/websocket": "11.2.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "fastify-type-provider-zod": "6.1.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "postgres": "3.4.9",
    "ws": "8.20.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.10",
    "@types/ws": "8.18.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
